{
    "name": "barnemax/wp-data-cli",
    "description": "CLI-first WordPress import library. Stream CSV and XLSX into WordPress via WP-CLI.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "barnemax",
            "email": "hello@barnemax.com"
        }
    ],
    "keywords": ["wordpress", "wp-cli", "import", "csv", "xlsx", "vip"],
    "require": {
        "php": ">=8.2",
        "phpoffice/phpspreadsheet": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "wp-coding-standards/wpcs": "^3.1",
        "automattic/vipwpcs": "^3.0",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "brain/monkey": "^2.6",
        "php-stubs/wordpress-stubs": "*",
        "squizlabs/php_codesniffer": "^3.10"
    },
    "autoload": {
        "psr-4": {
            "Barnemax\\WpDataCli\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Barnemax\\WpDataCli\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs": "phpcs",
        "cs:fix": "phpcbf"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
