# Normalize all text files to LF in the repo and on checkout.
* text=auto eol=lf

*.php   text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.dist  text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.xlsx  binary
